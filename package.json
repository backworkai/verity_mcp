{
  "name": "verity-mcp",
  "version": "1.0.0",
  "description": "MCP server for Verity healthcare API - Medicare coverage policies, prior auth, and medical codes",
  "type": "module",
  "bin": {
    "verity-mcp": "./build/src/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('build', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "node build/src/index.js",
    "start:http": "node build/src/index.js --http",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "healthcare",
    "medicare",
    "verity",
    "coverage",
    "prior-auth"
  ],
  "license": "MIT"
}
